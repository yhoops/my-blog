---
import "../styles/global.css"
import { getSiteConfig, themeToCssVars } from "../lib/config"
import SiteHeader from "../components/SiteHeader.astro"
import SiteFooter from "../components/SiteFooter.astro"

interface Props {
  title?: string
  description?: string
}

const site = getSiteConfig()
const { title, description } = Astro.props
const pageTitle = title ? `${title} — ${site.meta.title}` : site.meta.title
const pageDesc = description ?? site.meta.description
const cssVars = themeToCssVars(site.theme)
const headingFamily = site.theme.fonts.heading
const bodyFamily = site.theme.fonts.body
---

<!doctype html>
<html lang="zh-CN" style={cssVars} class="bg-bg">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="theme-color" content={site.theme.colors.bg} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={site.meta.title} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />

    <!-- Fonts: only load families referenced by the theme -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Playfair+Display:ital@0;1&family=Libre+Baskerville:ital@0;1&family=Lora:ital@0;1&family=Fraunces:ital,opsz@0,9..144;1,9..144&family=Geist:wght@400;500&family=Geist+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-ink focus:text-bg focus:px-3 focus:py-2">跳到主要内容</a>
    <div class="min-h-screen flex flex-col">
      <SiteHeader />
      <main id="main" class="flex-1">
        <slot />
      </main>
      <SiteFooter />
    </div>

    <!-- Scroll reveal: progressive enhancement, no layout cost if JS disabled -->
    <script>
      const revealVisible = (el) => {
        const rect = el.getBoundingClientRect()
        return rect.top < window.innerHeight * 0.92 && rect.bottom > 0
      }
      const revealAll = () => {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("is-visible"))
      }
      if (!("IntersectionObserver" in window)) {
        revealAll()
        document.documentElement.classList.add("reveal-ready")
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible")
                io.unobserve(entry.target)
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        )
        const init = () => {
          document.querySelectorAll(".reveal").forEach((el, i) => {
            if (el instanceof HTMLElement) {
              el.style.setProperty("--reveal-delay", `${Math.min(i * 60, 360)}ms`)
            if (i === 0 || revealVisible(el)) {
              el.classList.add("is-visible")
              return
            }
            }
            io.observe(el)
          })
          document.documentElement.classList.add("reveal-ready")
        }
        if (document.readyState !== "loading") init()
        else document.addEventListener("DOMContentLoaded", init)
      }
    </script>
  </body>
</html>
