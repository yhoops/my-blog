---
import type { CollectionEntry } from "astro:content"
import { getSiteConfig } from "../lib/config"
import KnowledgeTreeItem from "./KnowledgeTreeItem.astro"

interface TreeNode {
  name: string
  href?: string
  active?: boolean
  searchText: string
  children: Map<string, TreeNode>
}

interface RenderNode {
  name: string
  href?: string
  active?: boolean
  searchText: string
  children: RenderNode[]
}

interface Props {
  writing: CollectionEntry<"posts">[]
  projects?: CollectionEntry<"posts">[]
  activeSlug?: string
  mode?: "writing" | "work"
}

const { writing, projects = [], activeSlug = "", mode = "writing" } = Astro.props
const site = getSiteConfig()
const nav = site.content!.floatingNav

function createNode(name: string): TreeNode {
  return { name, searchText: name, children: new Map() }
}

function displayName(post: CollectionEntry<"posts">): string {
  return post.data.title || post.id.split("/").at(-1) || post.id
}

function postSegments(post: CollectionEntry<"posts">): string[] {
  const idParts = post.id.split("/").filter(Boolean)
  if (idParts.length > 1) return [...idParts.slice(0, -1), displayName(post)]
  const folderParts = (post.data.folder || "").split("/").filter(Boolean)
  return [...folderParts, displayName(post)]
}

const writingRoot = createNode(nav.writingLabel)
for (const post of writing) {
  let cursor = writingRoot
  for (const segment of postSegments(post)) {
    if (!cursor.children.has(segment)) cursor.children.set(segment, createNode(segment))
    cursor = cursor.children.get(segment)!
  }
  cursor.href = `/writing/${post.id}`
  cursor.active = post.id === activeSlug
  cursor.searchText = `${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(" ")}`
}

const projectRoot = createNode(nav.workLabel)
for (const project of projects) {
  const name = displayName(project)
  projectRoot.children.set(name, {
    name,
    href: `/work/${project.id}`,
    active: project.id === activeSlug,
    searchText: `${project.data.title} ${project.data.description} ${project.data.tags.join(" ")}`,
    children: new Map(),
  })
}

function entries(node: TreeNode): RenderNode[] {
  return [...node.children.values()].sort((a, b) => {
    const folderDelta = Number(Boolean(b.children.size)) - Number(Boolean(a.children.size))
    return folderDelta || a.name.localeCompare(b.name)
  }).map((child) => ({
    name: child.name,
    href: child.href,
    active: child.active || [...child.children.values()].some((grandchild) => grandchild.active),
    searchText: child.searchText,
    children: entries(child),
  }))
}
---

<aside class="knowledge-dock" data-knowledge-dock>
  <div class="dock-card">
    <header class="dock-head">
      <h2>{nav.title}</h2>
      <div class="dock-actions" aria-label="Display settings">
        <button class="icon-button" data-theme-toggle aria-label="切换深色或浅色模式">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v2m0 14v2M5.64 5.64l1.42 1.42m9.88 9.88 1.42 1.42M3 12h2m14 0h2M5.64 18.36l1.42-1.42m9.88-9.88 1.42-1.42M12 8a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" /></svg>
        </button>
        <button class="icon-button reading-trigger" data-reading-toggle aria-label={nav.readingLabel}>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5v-16Zm0 0A2.5 2.5 0 0 1 6.5 8H20" /></svg>
          <span>{nav.readingLabel}</span>
        </button>
      </div>
    </header>

    <label class="dock-search">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 21-4.35-4.35m1.35-5.65a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z" /></svg>
      <input type="search" placeholder={nav.searchPlaceholder} data-knowledge-search />
    </label>

    <div class="dock-scroll">
      <details class="tree-group" open={mode === "writing"}>
        <summary>{nav.writingLabel}</summary>
        <ul class="tree-list">
          {entries(writingRoot).map((node) => <KnowledgeTreeItem node={node} />)}
        </ul>
      </details>

      {projectRoot.children.size > 0 && (
        <details class="tree-group" open={mode === "work"}>
          <summary>{nav.workLabel}</summary>
          <ul class="tree-list">
            {entries(projectRoot).map((node) => <KnowledgeTreeItem node={node} />)}
          </ul>
        </details>
      )}
    </div>
  </div>
  <div class="theme-ripple" data-theme-ripple></div>
</aside>

<style>
  .knowledge-dock {
    position: fixed;
    left: clamp(0.9rem, 3vw, 3rem);
    top: 5.25rem;
    z-index: 30;
    width: 252px;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: 0.78rem;
    line-height: 1.35;
  }
  .dock-card {
    height: min(560px, calc(100vh - 7rem));
    display: flex;
    flex-direction: column;
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-line) 86%, transparent);
    border-radius: calc(var(--radius) + 14px);
    padding: 0.95rem;
    box-shadow: 0 18px 54px rgba(28, 22, 14, 0.11);
    backdrop-filter: blur(18px);
  }
  .dock-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding-bottom: 0.72rem;
    border-bottom: 1px solid var(--color-line);
    flex: 0 0 auto;
  }
  .dock-card h2 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .dock-actions {
    display: flex;
    gap: 0.15rem;
    align-items: center;
  }
  .dock-search {
    display: flex;
    align-items: center;
    gap: 0.42rem;
    background: var(--color-surface);
    border-radius: calc(var(--radius) + 8px);
    padding: 0.46rem 0.58rem;
    margin: 0.82rem 0;
    flex: 0 0 auto;
  }
  .dock-search svg,
  .icon-button svg {
    width: 1rem;
    height: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .dock-search input {
    min-width: 0;
    width: 100%;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--color-ink);
    font: inherit;
  }
  .icon-button {
    width: 1.8rem;
    height: 1.8rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--color-ink);
    display: inline-grid;
    place-items: center;
    cursor: pointer;
    position: relative;
  }
  .icon-button:hover {
    background: var(--color-surface);
  }
  .reading-trigger span {
    position: absolute;
    right: 0;
    top: calc(100% + 0.35rem);
    transform: translateY(-0.25rem);
    opacity: 0;
    pointer-events: none;
    white-space: nowrap;
    background: var(--color-ink);
    color: var(--color-bg);
    border-radius: 999px;
    padding: 0.22rem 0.5rem;
    font-size: 0.68rem;
    transition: opacity 220ms var(--anim-ease), transform 220ms var(--anim-ease);
  }
  .knowledge-dock:hover .reading-trigger span {
    opacity: 1;
    transform: translateY(0);
  }
  .dock-scroll {
    flex: 1 1 auto;
    min-height: 0;
    overflow: auto;
    padding-right: 0.25rem;
    scrollbar-width: thin;
  }
  .tree-group {
    margin-bottom: 0.65rem;
  }
  summary {
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    color: var(--color-ink);
    user-select: none;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary::before {
    content: "›";
    display: inline-block;
    color: var(--color-accent);
    margin-right: 0.38rem;
    transition: transform 160ms ease;
  }
  details[open] > summary::before {
    transform: rotate(90deg);
  }
  :global(.tree-list) {
    list-style: none;
    margin: 0.42rem 0 0.6rem 0.74rem;
    padding: 0;
  }
  :global(.tree-item) {
    margin: 0.2rem 0;
  }
  :global(.tree-link),
  :global(.tree-label) {
    display: block;
    color: var(--color-muted);
    font-size: 0.76rem;
    line-height: 1.35;
    padding: 0.12rem 0;
  }
  :global(.tree-label) {
    font-weight: 650;
    color: var(--color-ink);
  }
  :global(.tree-link) {
    transition: color 160ms ease, transform 160ms ease;
  }
  :global(.tree-link:hover),
  :global(.tree-link.active) {
    color: var(--color-accent);
    transform: translateX(2px);
  }
  .theme-ripple {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: var(--ripple-color, #16130f);
    clip-path: circle(0 at var(--ripple-x, 0) var(--ripple-y, 0));
    transition: clip-path 720ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .theme-ripple.spread {
    clip-path: circle(150vmax at var(--ripple-x, 0) var(--ripple-y, 0));
  }
  html.theme-dark {
    --color-bg: #14110d;
    --color-surface: #201b15;
    --color-ink: #f2eadc;
    --color-muted: #b7ab98;
    --color-faint: #7f7567;
    --color-line: #3a3026;
    --color-accent-soft: #4b3529;
  }
  html.reading-mode main {
    font-size: 1.08em;
  }
  html.reading-mode .prose {
    max-width: min(48rem, calc(100vw - 2rem));
    line-height: 1.9;
  }
  @media (max-width: 1180px) {
    .knowledge-dock {
      position: sticky;
      top: 0.75rem;
      width: auto;
      margin: 1rem;
    }
    .dock-card {
      height: 360px;
    }
  }
</style>

<script>
  const dock = document.querySelector("[data-knowledge-dock]")
  const search = dock?.querySelector<HTMLInputElement>("[data-knowledge-search]")
  const themeButton = dock?.querySelector<HTMLButtonElement>("[data-theme-toggle]")
  const readingButton = dock?.querySelector<HTMLButtonElement>("[data-reading-toggle]")
  const ripple = dock?.querySelector<HTMLElement>("[data-theme-ripple]")

  const savedTheme = localStorage.getItem("site-theme")
  if (savedTheme === "dark") document.documentElement.classList.add("theme-dark")
  if (localStorage.getItem("reading-mode") === "on") document.documentElement.classList.add("reading-mode")

  search?.addEventListener("input", () => {
    const q = search.value.trim().toLowerCase()
    dock?.querySelectorAll<HTMLElement>("[data-search-item]").forEach((item) => {
      const text = item.dataset.searchItem?.toLowerCase() ?? ""
      item.hidden = Boolean(q && !text.includes(q))
    })
  })

  themeButton?.addEventListener("click", () => {
    const rect = themeButton.getBoundingClientRect()
    const x = `${rect.left + rect.width / 2}px`
    const y = `${rect.top + rect.height / 2}px`
    const nextDark = !document.documentElement.classList.contains("theme-dark")
    ripple?.style.setProperty("--ripple-x", x)
    ripple?.style.setProperty("--ripple-y", y)
    ripple?.style.setProperty("--ripple-color", nextDark ? "#14110d" : "var(--color-bg)")
    ripple?.classList.add("spread")
    window.setTimeout(() => {
      document.documentElement.classList.toggle("theme-dark", nextDark)
      localStorage.setItem("site-theme", nextDark ? "dark" : "light")
      ripple?.classList.remove("spread")
    }, 360)
  })

  readingButton?.addEventListener("click", () => {
    const on = !document.documentElement.classList.contains("reading-mode")
    document.documentElement.classList.toggle("reading-mode", on)
    localStorage.setItem("reading-mode", on ? "on" : "off")
  })
</script>
