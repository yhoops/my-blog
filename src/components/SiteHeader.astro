---
import { getSiteConfig } from "../lib/config"
const site = getSiteConfig()
const path = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href)
---

<header class="w-full">
  <div class="mx-auto max-w-3xl px-6 md:px-8 py-8 flex items-baseline justify-between gap-6">
    <a href="/" class="font-serif text-lg tracking-tight link-underline">
      {site.meta.title}
    </a>
    <nav aria-label="主导航" class="flex items-baseline gap-5 text-sm">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              "link-underline transition-colors",
              isActive(item.href) ? "text-ink" : "text-muted hover:text-ink",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
