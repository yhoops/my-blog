---
import { getSiteConfig } from "../lib/config"
const site = getSiteConfig()
const year = new Date().getFullYear()
---

<footer class="w-full border-t border-line mt-24">
  <div class="mx-auto max-w-3xl px-6 md:px-8 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-sm text-muted">
    <div class="flex items-center gap-3">
      <p>© {year} {site.meta.author}</p>
      <a
        href="/studio"
        aria-label="管理后台"
        class="admin-entry"
        title="Studio"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
      </a>
    </div>
    <nav aria-label="社交链接" class="flex items-center gap-5">
      {
        site.social.map((item) => (
          <a
            href={item.href}
            class="link-underline hover:text-ink transition-colors"
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>

<style>
  .admin-entry {
    display: inline-flex;
    align-items: center;
    color: var(--color-line);
    transition: color 300ms ease;
    line-height: 1;
  }
  .admin-entry:hover {
    color: var(--color-faint);
  }
</style>
