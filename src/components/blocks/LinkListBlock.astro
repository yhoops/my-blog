---
interface Props {
  props: {
    heading?: string
    items?: { label: string; href: string; note?: string }[]
  }
}
const { props } = Astro.props
const items = props.items ?? []
---

<section class="mx-auto max-w-3xl px-6 md:px-8 py-12">
  <h2 class="reveal text-sm uppercase tracking-[0.18em] text-faint mb-8">
    {props.heading ?? "在别处"}
  </h2>
  <ul class="flex flex-col">
    {
      items.map((item) => (
        <li class="reveal border-t border-line">
          <a
            href={item.href}
            target={item.href.startsWith("http") ? "_blank" : undefined}
            rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="group flex items-baseline justify-between gap-4 py-5"
          >
            <span class="text-xl md:text-2xl group-hover:text-accent transition-colors duration-300">
              {item.label}
            </span>
            <span class="text-sm text-muted text-right">{item.note}</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>
