---
interface Props {
  props: { name?: string; tagline?: string; intro?: string }
}
const { props } = Astro.props
---

<section class="mx-auto max-w-3xl px-6 md:px-8 pt-10 pb-16 md:pt-16 md:pb-24">
  <p class="reveal text-sm text-accent tracking-wide mb-5">{props.tagline}</p>
  <h1 class="reveal text-4xl md:text-6xl leading-[1.05] text-balance mb-8" style="--reveal-delay:80ms">
    {props.name}
  </h1>
  <p class="reveal text-lg md:text-xl text-muted leading-relaxed text-pretty" style="--reveal-delay:160ms; max-width:var(--measure)">
    {props.intro}
  </p>
</section>
