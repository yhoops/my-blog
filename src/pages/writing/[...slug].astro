---
import { getCollection, render } from "astro:content"
import BaseLayout from "../../layouts/BaseLayout.astro"
import FloatingKnowledgeNav from "../../components/FloatingKnowledgeNav.astro"
import RightContextRail from "../../components/RightContextRail.astro"
import { formatDate, getAllPosts, getCanonicalSlug } from "../../lib/posts"

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => data.kind === "writing" && !data.draft)
  return posts.flatMap((post) => {
    const canonical = getCanonicalSlug(post)
    const aliases = post.data.aliases ?? []
    return [
      { params: { slug: canonical }, props: { post, requestedSlug: canonical } },
      ...aliases.map((alias) => ({ params: { slug: alias }, props: { post, requestedSlug: alias } })),
    ]
  })
}

const { post, requestedSlug } = Astro.props
const { Content, headings } = await render(post)
const allPosts = await getAllPosts()
const writing = allPosts.filter((p) => p.data.kind === "writing").sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const projects = allPosts.filter((p) => p.data.kind === "project").sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
const canonicalSlug = getCanonicalSlug(post)
if (requestedSlug !== canonicalSlug) {
  return Astro.redirect(`/writing/${encodeURIComponent(canonicalSlug)}/`, 301)
}
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <FloatingKnowledgeNav writing={writing} projects={projects} activeSlug={canonicalSlug} mode="writing" />
  <RightContextRail post={post} headings={headings} />
  <article class="mx-auto max-w-3xl px-6 md:px-8 pt-10 pb-16">
    <header class="reveal mb-12">
      <a href="/writing" class="text-sm text-muted hover:text-ink link-underline">← 随笔</a>
      <h1 class="text-3xl md:text-5xl leading-tight text-balance mt-6 mb-4">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-3 text-sm text-faint flex-wrap">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        {post.data.category && post.data.category !== "未分类" && (
          <>
            <span aria-hidden="true">·</span>
            <a href={`/writing/category/${encodeURIComponent(post.data.category)}`} class="hover:text-accent link-underline">
              {post.data.category}
            </a>
          </>
        )}
        {post.data.tags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            {post.data.tags.map((tag, i) => (
              <span>
                {i > 0 && <span class="mx-1 text-faint" aria-hidden="true">/</span>}
                <a href={`/writing/tag/${encodeURIComponent(tag)}`} class="hover:text-accent link-underline">
                  #{tag}
                </a>
              </span>
            ))}
          </>
        )}
      </div>
    </header>
    <div class="reveal prose" style="--reveal-delay:120ms">
      <Content />
    </div>
  </article>
</BaseLayout>
