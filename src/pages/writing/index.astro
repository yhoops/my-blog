---
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getWriting, formatDate } from "../../lib/posts"

const posts = await getWriting()
---

<BaseLayout title="随笔" description="所有随笔文章">
  <section class="mx-auto max-w-3xl px-6 md:px-8 pt-10 pb-12">
    <h1 class="reveal text-4xl md:text-5xl mb-3">随笔</h1>
    <p class="reveal text-muted text-lg" style="--reveal-delay:80ms">
      关于设计、写作与日常的思考。
    </p>
  </section>
  <section class="mx-auto max-w-3xl px-6 md:px-8 pb-16">
    <ul class="flex flex-col">
      {
        posts.map((post) => (
          <li class="reveal border-t border-line">
            <a href={`/writing/${post.id}`} class="group block py-6">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="text-xl md:text-2xl group-hover:text-accent transition-colors duration-300">
                  {post.data.title}
                </h2>
                <time class="shrink-0 text-sm text-faint tabular-nums" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              {post.data.description && (
                <p class="mt-2 text-muted leading-relaxed text-pretty" style="max-width:var(--measure)">
                  {post.data.description}
                </p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
