---
import BaseLayout from "../layouts/BaseLayout.astro"
import { getSiteConfig } from "../lib/config"

const site = getSiteConfig()
---

<BaseLayout title="关于" description={`关于 ${site.meta.author}`}>
  <section class="mx-auto max-w-3xl px-6 md:px-8 pt-10 pb-16">
    <h1 class="reveal text-4xl md:text-5xl mb-10">关于</h1>
    <div class="reveal prose" style="--reveal-delay:80ms">
      <p>
        我是{site.meta.author}，一名写作者与界面设计师。我相信好的设计是克制的——它把注意力还给内容本身，而不是争抢眼球。
      </p>
      <p>
        这个网站是我的自留地。我在这里记录关于设计、代码与阅读的思考，也展示一些自己做过的项目。它由 Astro 构建，部署在 Cloudflare 上，所有内容都以 Markdown 形式存放在 GitHub 仓库里。
      </p>
      <p>
        如果你想聊聊，欢迎通过下面的方式找到我。
      </p>
    </div>
    <ul class="reveal mt-10 flex flex-col" style="--reveal-delay:160ms">
      {
        site.social.map((item) => (
          <li class="border-t border-line">
            <a
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="group flex items-baseline justify-between py-4"
            >
              <span class="text-lg group-hover:text-accent transition-colors">{item.label}</span>
              <span class="text-sm text-faint">↗</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
