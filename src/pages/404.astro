---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="页面未找到">
  <section class="mx-auto max-w-3xl px-6 md:px-8 py-32 text-center">
    <p class="text-sm text-accent tracking-wide mb-4">404</p>
    <h1 class="text-4xl md:text-5xl mb-6">这里什么都没有</h1>
    <p class="text-muted text-lg mb-10">你要找的页面也许已经搬走了。</p>
    <a href="/" class="text-accent link-underline">← 回到首页</a>
  </section>
</BaseLayout>
