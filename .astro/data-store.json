[["Map",1,2,9,10],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.2","content-config-digest","2cf00fbd9108dab0","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://example.vercel.app\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":true,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"prefetch\":{\"prefetchAll\":true,\"defaultStrategy\":\"viewport\"},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","posts",["Map",11,12,39,40,67,68,91,92,114,115],"atelier",{"id":11,"data":13,"body":26,"filePath":27,"digest":28,"rendered":29},{"title":14,"description":15,"date":16,"tags":17,"category":18,"folder":20,"kind":21,"draft":22,"year":23,"role":24,"url":25},"Atelier 设计系统","一套以排版为核心的开源设计系统。",["Date","2026-02-10T00:00:00.000Z"],[18,19],"设计系统","开源","","project",false,"2026","设计与开发","https://github.com","Atelier 是一套围绕排版与留白构建的设计系统，目标是让内容型网站默认就拥有优雅的阅读体验。\r\n\r\n它包含一套模块化的字号比例、一组克制的中性色板，以及最小化的组件集合。整个系统的哲学是\"少即是多\"——只提供真正必要的东西。","src/content/posts/atelier.md","19cdc78f08fa798d",{"html":30,"metadata":31},"\u003Cp>Atelier 是一套围绕排版与留白构建的设计系统，目标是让内容型网站默认就拥有优雅的阅读体验。\u003C/p>\n\u003Cp>它包含一套模块化的字号比例、一组克制的中性色板，以及最小化的组件集合。整个系统的哲学是”少即是多”——只提供真正必要的东西。\u003C/p>",{"headings":32,"localImagePaths":33,"remoteImagePaths":34,"frontmatter":35,"imagePaths":38},[],[],[],{"title":14,"description":15,"date":36,"tags":37,"category":18,"kind":21,"draft":22,"year":23,"role":24,"url":25},["Date","2026-02-10T00:00:00.000Z"],[18,19],[],"on-restraint",{"id":39,"data":41,"body":49,"filePath":50,"digest":51,"rendered":52},{"title":42,"description":43,"date":44,"tags":45,"category":46,"folder":20,"kind":48,"draft":22},"论克制","为什么最好的设计往往是你看不见的那部分。",["Date","2026-05-12T00:00:00.000Z"],[46,47],"设计","随笔","writing","我越来越相信，设计的成熟不在于你能加上什么，而在于你愿意拿掉什么。\r\n\r\n界面里每一个元素都在向用户索取注意力。一个按钮、一道阴影、一段动画——它们都不是免费的。当我们把它们一股脑堆上去，得到的不是丰富，而是噪音。\r\n\r\n## 留白不是空\r\n\r\n留白常被误解为\"还没填满的地方\"。但在好的排版里，留白是有重量的。它给文字呼吸的空间，给眼睛停留的余地。一页纸上最优雅的部分，往往是那些什么都没有的部分。\r\n\r\n> 完美不是无可增加，而是无可删减。\r\n\r\n## 动效要服务于理解\r\n\r\n动画的目的从来不是炫技，而是帮助用户理解状态的变化——一个元素从哪里来，到哪里去。当动效安静地服务于这个目标时，它几乎是隐形的。一旦它开始表演，就成了干扰。\r\n\r\n所以我给自己定了一条规矩：每加一样东西之前，先问一句——拿掉它会更好吗？","src/content/posts/on-restraint.md","a6b35e99838fcd24",{"html":53,"metadata":54},"\u003Cp>我越来越相信，设计的成熟不在于你能加上什么，而在于你愿意拿掉什么。\u003C/p>\n\u003Cp>界面里每一个元素都在向用户索取注意力。一个按钮、一道阴影、一段动画——它们都不是免费的。当我们把它们一股脑堆上去，得到的不是丰富，而是噪音。\u003C/p>\n\u003Ch2 id=\"留白不是空\">留白不是空\u003C/h2>\n\u003Cp>留白常被误解为”还没填满的地方”。但在好的排版里，留白是有重量的。它给文字呼吸的空间，给眼睛停留的余地。一页纸上最优雅的部分，往往是那些什么都没有的部分。\u003C/p>\n\u003Cblockquote>\n\u003Cp>完美不是无可增加，而是无可删减。\u003C/p>\n\u003C/blockquote>\n\u003Ch2 id=\"动效要服务于理解\">动效要服务于理解\u003C/h2>\n\u003Cp>动画的目的从来不是炫技，而是帮助用户理解状态的变化——一个元素从哪里来，到哪里去。当动效安静地服务于这个目标时，它几乎是隐形的。一旦它开始表演，就成了干扰。\u003C/p>\n\u003Cp>所以我给自己定了一条规矩：每加一样东西之前，先问一句——拿掉它会更好吗？\u003C/p>",{"headings":55,"localImagePaths":61,"remoteImagePaths":62,"frontmatter":63,"imagePaths":66},[56,59],{"depth":57,"slug":58,"text":58},2,"留白不是空",{"depth":57,"slug":60,"text":60},"动效要服务于理解",[],[],{"title":42,"description":43,"date":64,"tags":65,"category":46,"kind":48,"draft":22},["Date","2026-05-12T00:00:00.000Z"],[46,47],[],"quietype",{"id":67,"data":69,"body":78,"filePath":79,"digest":80,"rendered":81},{"title":70,"description":71,"date":72,"tags":73,"category":74,"folder":20,"kind":21,"draft":22,"year":76,"role":77,"url":25},"Quietype 写作工具","一个专注于心流的极简纯文本编辑器。",["Date","2025-11-04T00:00:00.000Z"],[74,75],"工具","写作","2025","独立开发","Quietype 是一个去除一切干扰的写作工具。没有工具栏，没有格式按钮，只有文字和光标。\r\n\r\n它的设计前提是：写作时最需要的不是更多功能，而是更少。所有格式通过 Markdown 完成，所有界面在你停止打字时悄然隐去。","src/content/posts/quietype.md","3026c41a9ba24aed",{"html":82,"metadata":83},"\u003Cp>Quietype 是一个去除一切干扰的写作工具。没有工具栏，没有格式按钮，只有文字和光标。\u003C/p>\n\u003Cp>它的设计前提是：写作时最需要的不是更多功能，而是更少。所有格式通过 Markdown 完成，所有界面在你停止打字时悄然隐去。\u003C/p>",{"headings":84,"localImagePaths":85,"remoteImagePaths":86,"frontmatter":87,"imagePaths":90},[],[],[],{"title":70,"description":71,"date":88,"tags":89,"category":74,"kind":21,"draft":22,"year":76,"role":77,"url":25},["Date","2025-11-04T00:00:00.000Z"],[74,75],[],"reading-as-writing",{"id":91,"data":93,"body":99,"filePath":100,"digest":101,"rendered":102},{"title":94,"description":95,"date":96,"tags":97,"category":75,"folder":20,"kind":48,"draft":22},"把阅读当作写作","关于输入与输出之间那条常被忽略的通道。",["Date","2026-03-28T00:00:00.000Z"],[75,98],"思考","我们常把阅读和写作当成两件事：一个是输入，一个是输出。但实际上，真正有效的阅读本身就是一种写作。\r\n\r\n当你读到一句让你停顿的话，那个停顿就是你在心里重写它。你在问：我同意吗？我会怎么说这件事？这种内在的对话，比划线和摘抄都更接近写作的本质。\r\n\r\n## 慢下来\r\n\r\n信息越来越快，但理解从来都是慢的。我开始刻意地慢读——一篇好文章读两遍，第二遍只为找出作者是怎么搭建论证的。\r\n\r\n这让我写得更好，因为我终于看清了别人是怎么写的。","src/content/posts/reading-as-writing.md","6a84dd8afce6a149",{"html":103,"metadata":104},"\u003Cp>我们常把阅读和写作当成两件事：一个是输入，一个是输出。但实际上，真正有效的阅读本身就是一种写作。\u003C/p>\n\u003Cp>当你读到一句让你停顿的话，那个停顿就是你在心里重写它。你在问：我同意吗？我会怎么说这件事？这种内在的对话，比划线和摘抄都更接近写作的本质。\u003C/p>\n\u003Ch2 id=\"慢下来\">慢下来\u003C/h2>\n\u003Cp>信息越来越快，但理解从来都是慢的。我开始刻意地慢读——一篇好文章读两遍，第二遍只为找出作者是怎么搭建论证的。\u003C/p>\n\u003Cp>这让我写得更好，因为我终于看清了别人是怎么写的。\u003C/p>",{"headings":105,"localImagePaths":108,"remoteImagePaths":109,"frontmatter":110,"imagePaths":113},[106],{"depth":57,"slug":107,"text":107},"慢下来",[],[],{"title":94,"description":95,"date":111,"tags":112,"category":75,"kind":48,"draft":22},["Date","2026-03-28T00:00:00.000Z"],[75,98],[],"测试/测试",{"id":114,"data":116,"body":117,"filePath":121,"digest":122,"rendered":123},{"title":117,"description":117,"date":118,"tags":119,"category":120,"folder":117,"kind":48,"draft":22},"测试",["Date","2026-06-30T00:00:00.000Z"],[],"大数据","src/content/posts/测试/测试.md","962907e1b55677ac",{"html":124,"metadata":125},"\u003Cp>测试\u003C/p>",{"headings":126,"localImagePaths":127,"remoteImagePaths":128,"frontmatter":129,"imagePaths":131},[],[],[],{"title":117,"description":117,"date":130,"kind":48,"category":120,"folder":117,"draft":22},["Date","2026-06-30T00:00:00.000Z"],[]]