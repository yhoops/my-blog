[["Map",1,2,9,10],"meta::meta",["Map",3,4,5,6,7,8],"astro-version","5.18.2","content-config-digest","b9ad69f5f2277a6b","astro-config-digest","{\"root\":{},\"srcDir\":{},\"publicDir\":{},\"outDir\":{},\"cacheDir\":{},\"site\":\"https://example.vercel.app\",\"compressHTML\":true,\"base\":\"/\",\"trailingSlash\":\"ignore\",\"output\":\"static\",\"scopedStyleStrategy\":\"attribute\",\"build\":{\"format\":\"directory\",\"client\":{},\"server\":{},\"assets\":\"_astro\",\"serverEntry\":\"entry.mjs\",\"redirects\":false,\"inlineStylesheets\":\"auto\",\"concurrency\":1},\"server\":{\"open\":false,\"host\":true,\"port\":4321,\"streaming\":true,\"allowedHosts\":[]},\"redirects\":{},\"prefetch\":{\"prefetchAll\":true,\"defaultStrategy\":\"viewport\"},\"image\":{\"endpoint\":{\"route\":\"/_image\"},\"service\":{\"entrypoint\":\"astro/assets/services/sharp\",\"config\":{}},\"domains\":[],\"remotePatterns\":[],\"responsiveStyles\":false},\"devToolbar\":{\"enabled\":true},\"markdown\":{\"syntaxHighlight\":{\"type\":\"shiki\",\"excludeLangs\":[\"math\"]},\"shikiConfig\":{\"langs\":[],\"langAlias\":{},\"theme\":\"github-dark\",\"themes\":{},\"wrap\":false,\"transformers\":[]},\"remarkPlugins\":[],\"rehypePlugins\":[],\"remarkRehype\":{},\"gfm\":true,\"smartypants\":true},\"security\":{\"checkOrigin\":true,\"allowedDomains\":[],\"actionBodySizeLimit\":1048576},\"env\":{\"schema\":{},\"validateSecrets\":false},\"experimental\":{\"clientPrerender\":false,\"contentIntellisense\":false,\"headingIdCompat\":false,\"preserveScriptOrder\":false,\"liveContentCollections\":false,\"csp\":false,\"staticImportMetaEnv\":false,\"chromeDevtoolsWorkspace\":false,\"failOnPrerenderConflict\":false,\"svgo\":false},\"legacy\":{\"collections\":false}}","posts",["Map",11,12,38,39,66,67,90,91],"atelier",{"id":11,"data":13,"body":25,"filePath":26,"digest":27,"rendered":28},{"title":14,"description":15,"date":16,"tags":17,"kind":20,"draft":21,"year":22,"role":23,"url":24},"Atelier 设计系统","一套以排版为核心的开源设计系统。",["Date","2026-02-10T00:00:00.000Z"],[18,19],"设计系统","开源","project",false,"2026","设计与开发","https://github.com","Atelier 是一套围绕排版与留白构建的设计系统，目标是让内容型网站默认就拥有优雅的阅读体验。\n\n它包含一套模块化的字号比例、一组克制的中性色板，以及最小化的组件集合。整个系统的哲学是\"少即是多\"——只提供真正必要的东西。","src/content/posts/atelier.md","c6bef6c6bf3f901a",{"html":29,"metadata":30},"\u003Cp>Atelier 是一套围绕排版与留白构建的设计系统，目标是让内容型网站默认就拥有优雅的阅读体验。\u003C/p>\n\u003Cp>它包含一套模块化的字号比例、一组克制的中性色板，以及最小化的组件集合。整个系统的哲学是”少即是多”——只提供真正必要的东西。\u003C/p>",{"headings":31,"localImagePaths":32,"remoteImagePaths":33,"frontmatter":34,"imagePaths":37},[],[],[],{"title":14,"description":15,"date":35,"tags":36,"kind":20,"draft":21,"year":22,"role":23,"url":24},["Date","2026-02-10T00:00:00.000Z"],[18,19],[],"on-restraint",{"id":38,"data":40,"body":48,"filePath":49,"digest":50,"rendered":51},{"title":41,"description":42,"date":43,"tags":44,"kind":47,"draft":21},"论克制","为什么最好的设计往往是你看不见的那部分。",["Date","2026-05-12T00:00:00.000Z"],[45,46],"设计","随笔","writing","我越来越相信，设计的成熟不在于你能加上什么，而在于你愿意拿掉什么。\n\n界面里每一个元素都在向用户索取注意力。一个按钮、一道阴影、一段动画——它们都不是免费的。当我们把它们一股脑堆上去，得到的不是丰富，而是噪音。\n\n## 留白不是空\n\n留白常被误解为\"还没填满的地方\"。但在好的排版里，留白是有重量的。它给文字呼吸的空间，给眼睛停留的余地。一页纸上最优雅的部分，往往是那些什么都没有的部分。\n\n> 完美不是无可增加，而是无可删减。\n\n## 动效要服务于理解\n\n动画的目的从来不是炫技，而是帮助用户理解状态的变化——一个元素从哪里来，到哪里去。当动效安静地服务于这个目标时，它几乎是隐形的。一旦它开始表演，就成了干扰。\n\n所以我给自己定了一条规矩：每加一样东西之前，先问一句——拿掉它会更好吗？","src/content/posts/on-restraint.md","ace86986bd77149d",{"html":52,"metadata":53},"\u003Cp>我越来越相信，设计的成熟不在于你能加上什么，而在于你愿意拿掉什么。\u003C/p>\n\u003Cp>界面里每一个元素都在向用户索取注意力。一个按钮、一道阴影、一段动画——它们都不是免费的。当我们把它们一股脑堆上去，得到的不是丰富，而是噪音。\u003C/p>\n\u003Ch2 id=\"留白不是空\">留白不是空\u003C/h2>\n\u003Cp>留白常被误解为”还没填满的地方”。但在好的排版里，留白是有重量的。它给文字呼吸的空间，给眼睛停留的余地。一页纸上最优雅的部分，往往是那些什么都没有的部分。\u003C/p>\n\u003Cblockquote>\n\u003Cp>完美不是无可增加，而是无可删减。\u003C/p>\n\u003C/blockquote>\n\u003Ch2 id=\"动效要服务于理解\">动效要服务于理解\u003C/h2>\n\u003Cp>动画的目的从来不是炫技，而是帮助用户理解状态的变化——一个元素从哪里来，到哪里去。当动效安静地服务于这个目标时，它几乎是隐形的。一旦它开始表演，就成了干扰。\u003C/p>\n\u003Cp>所以我给自己定了一条规矩：每加一样东西之前，先问一句——拿掉它会更好吗？\u003C/p>",{"headings":54,"localImagePaths":60,"remoteImagePaths":61,"frontmatter":62,"imagePaths":65},[55,58],{"depth":56,"slug":57,"text":57},2,"留白不是空",{"depth":56,"slug":59,"text":59},"动效要服务于理解",[],[],{"title":41,"description":42,"date":63,"tags":64,"kind":47,"draft":21},["Date","2026-05-12T00:00:00.000Z"],[45,46],[],"quietype",{"id":66,"data":68,"body":77,"filePath":78,"digest":79,"rendered":80},{"title":69,"description":70,"date":71,"tags":72,"kind":20,"draft":21,"year":75,"role":76,"url":24},"Quietype 写作工具","一个专注于心流的极简纯文本编辑器。",["Date","2025-11-04T00:00:00.000Z"],[73,74],"工具","写作","2025","独立开发","Quietype 是一个去除一切干扰的写作工具。没有工具栏，没有格式按钮，只有文字和光标。\n\n它的设计前提是：写作时最需要的不是更多功能，而是更少。所有格式通过 Markdown 完成，所有界面在你停止打字时悄然隐去。","src/content/posts/quietype.md","1d4b2e39e477d356",{"html":81,"metadata":82},"\u003Cp>Quietype 是一个去除一切干扰的写作工具。没有工具栏，没有格式按钮，只有文字和光标。\u003C/p>\n\u003Cp>它的设计前提是：写作时最需要的不是更多功能，而是更少。所有格式通过 Markdown 完成，所有界面在你停止打字时悄然隐去。\u003C/p>",{"headings":83,"localImagePaths":84,"remoteImagePaths":85,"frontmatter":86,"imagePaths":89},[],[],[],{"title":69,"description":70,"date":87,"tags":88,"kind":20,"draft":21,"year":75,"role":76,"url":24},["Date","2025-11-04T00:00:00.000Z"],[73,74],[],"reading-as-writing",{"id":90,"data":92,"body":98,"filePath":99,"digest":100,"rendered":101},{"title":93,"description":94,"date":95,"tags":96,"kind":47,"draft":21},"把阅读当作写作","关于输入与输出之间那条常被忽略的通道。",["Date","2026-03-28T00:00:00.000Z"],[74,97],"思考","我们常把阅读和写作当成两件事：一个是输入，一个是输出。但实际上，真正有效的阅读本身就是一种写作。\n\n当你读到一句让你停顿的话，那个停顿就是你在心里重写它。你在问：我同意吗？我会怎么说这件事？这种内在的对话，比划线和摘抄都更接近写作的本质。\n\n## 慢下来\n\n信息越来越快，但理解从来都是慢的。我开始刻意地慢读——一篇好文章读两遍，第二遍只为找出作者是怎么搭建论证的。\n\n这让我写得更好，因为我终于看清了别人是怎么写的。","src/content/posts/reading-as-writing.md","cc085fbe7dde7375",{"html":102,"metadata":103},"\u003Cp>我们常把阅读和写作当成两件事：一个是输入，一个是输出。但实际上，真正有效的阅读本身就是一种写作。\u003C/p>\n\u003Cp>当你读到一句让你停顿的话，那个停顿就是你在心里重写它。你在问：我同意吗？我会怎么说这件事？这种内在的对话，比划线和摘抄都更接近写作的本质。\u003C/p>\n\u003Ch2 id=\"慢下来\">慢下来\u003C/h2>\n\u003Cp>信息越来越快，但理解从来都是慢的。我开始刻意地慢读——一篇好文章读两遍，第二遍只为找出作者是怎么搭建论证的。\u003C/p>\n\u003Cp>这让我写得更好，因为我终于看清了别人是怎么写的。\u003C/p>",{"headings":104,"localImagePaths":107,"remoteImagePaths":108,"frontmatter":109,"imagePaths":112},[105],{"depth":56,"slug":106,"text":106},"慢下来",[],[],{"title":93,"description":94,"date":110,"tags":111,"kind":47,"draft":21},["Date","2026-03-28T00:00:00.000Z"],[74,97],[]]