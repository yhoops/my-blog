            "writing",
            "project"
          ],
          "default": "writing"
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "cover": {
          "type": "string"
        },
        "year": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}